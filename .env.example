# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# API
API_HOST=127.0.0.1
API_PORT=8000

# Capture
CAPTURE_INTERFACE=Wi-Fi
CAPTURE_COUNT=100

# Notifications — Telegram (https://core.telegram.org/bots#how-do-i-create-a-bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Notifications — Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_USE_TLS=true
# Comma-separated list of recipients
EMAIL_RECIPIENTS=
