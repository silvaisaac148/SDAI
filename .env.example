# Supabase
# PROD: usa la "service_role" key (Project Settings → API). NUNCA expongas esta key al navegador.
# DEV : con anon key necesitas activar las policies "anon_dev_*" en db/schema.sql.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here

# API
API_HOST=127.0.0.1
API_PORT=8000

# Capture
CAPTURE_INTERFACE=Wi-Fi
CAPTURE_COUNT=100

# Notifications — Telegram (https://core.telegram.org/bots#how-do-i-create-a-bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Notifications — Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_USE_TLS=true
# Comma-separated list of recipients
EMAIL_RECIPIENTS=

# IA Defensiva y Educativa — Google Gemini API
GEMINI_API_KEY=

# IA Defensiva y Educativa — Groq API (openai-compatible)
GROQ_API_KEY=

# Autenticación SOC (bootstrap admin · fallback si tabla `users` vacía o DB offline)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION
# Genera uno aleatorio: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
# True solo cuando el dashboard se sirva sobre HTTPS — sino el navegador descarta la cookie.
SESSION_COOKIE_SECURE=false

# CORS — "*" para dev local, lista separada por coma en producción
# Ej. https://sdai.pyme.local,https://soc.pyme.local
CORS_ALLOWED_ORIGINS=*

