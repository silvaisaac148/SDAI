# Supabase
# PROD: usa la "service_role" key (Project Settings → API). NUNCA expongas esta key al navegador.
# DEV : con anon key necesitas activar las policies "anon_dev_*" en db/schema.sql.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here

# API
API_HOST=127.0.0.1
API_PORT=8000

# Capture
CAPTURE_INTERFACE=Wi-Fi
CAPTURE_COUNT=100

# Notifications — Telegram (https://core.telegram.org/bots#how-do-i-create-a-bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Notifications — Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_USE_TLS=true
# Comma-separated list of recipients
EMAIL_RECIPIENTS=

# =============================================================
# IA Defensiva y Educativa — REGISTRA TU PROPIA API KEY (gratis)
# =============================================================
# IMPORTANTE: Cada usuario debe usar su PROPIA API key.
# No reutilices keys de terceros — la cuota se agota y queda inservible para todos.
# Sin ninguna key configurada, el tutor IA funciona en modo heurístico local
# (respuestas pre-escritas, sin LLM real). Ver MANUAL_INSTALACION.md sección 10.5.
#
# Groq (RECOMENDADO — gratis, ~14,400 req/día, respuestas <1s):
#   1. https://console.groq.com → Sign up
#   2. API Keys → Create API Key → copiar
GROQ_API_KEY=
#
# Google Gemini (alternativa — gratis, 1,500 req/día):
#   1. https://aistudio.google.com/apikey → Create API key
#   2. Copiar la key (formato AIzaSy...)
GEMINI_API_KEY=

# Autenticación SOC (bootstrap admin · fallback si tabla `users` vacía o DB offline)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION
# Genera uno aleatorio: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
# True solo cuando el dashboard se sirva sobre HTTPS — sino el navegador descarta la cookie.
SESSION_COOKIE_SECURE=false

# CORS — "*" para dev local, lista separada por coma en producción
# Ej. https://sdai.pyme.local,https://soc.pyme.local
CORS_ALLOWED_ORIGINS=*

